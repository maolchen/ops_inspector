[project]
requires = ["nodejs-24", "golang-1.21"]

[dev]
build = ["pnpm", "install"]
run = ["pnpm", "dev"]

[deploy]
build = ["bash", "-c", "export GOROOT=/workspace/go && export PATH=$GOROOT/bin:$PATH && bash build.sh"]
run = ["bash", "-c", "export GOROOT=/workspace/go && export PATH=$GOROOT/bin:$PATH && bash start.sh"]
