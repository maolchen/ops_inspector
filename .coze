[project]
requires = ["nodejs-24", "golang-1.21"]

[dev]
build = ["bash", "-c", "cd frontend && pnpm install"]
run = ["bash", "-c", "cd frontend && pnpm dev --port 5000 --host"]

[deploy]
build = ["bash", "-c", "cd frontend && pnpm build"]
run = ["bash", "-c", "cd frontend && pnpm preview --port 5000 --host"]
